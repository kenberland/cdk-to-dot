digraph ElastiCacheArchitecture {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=11
        bgcolor="BG"
        color="FG"
        fontcolor="FG"
        pad=0.5
        nodesep=0.6
        ranksep=0.8
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="4">
                <TR><TD><B><FONT POINT-SIZE="14">ElastiCache Architecture</FONT></B></TD></TR>
                <TR><TD><FONT POINT-SIZE="9" COLOR="MUTED">Cache clusters, engine configuration, and placement</FONT></TD></TR>
            </TABLE>
        >
        labelloc=t
    ]

    node [
        fontname="Helvetica"
        fontsize=10
        style=filled
        color="BORDER"
        fontcolor="FG"
    ]

    edge [
        fontname="Helvetica"
        fontsize=8
        fontcolor="SUBTLE"
        color="EDGE"
    ]

    redis_a [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Valkey Cache</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.100</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">ElastiCache node</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Engine</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">valkey 7.2</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Node Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">cache.t3.micro</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Nodes</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">1</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.0.0/24 (us-east-1a)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    redis_b [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Valkey Cache</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.100</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">ElastiCache node</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Engine</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">valkey 7.2</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Node Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">cache.t3.micro</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Nodes</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">1</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.1.0/24 (us-east-1b)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    // ── Cache Connections ────────────────────────────
    app_servers_a -> redis_a [
        label="cache r/w"
        color="EDGE"
    ]
    app_servers_b -> redis_b [
        label="cache r/w"
        color="EDGE"
    ]

}
