digraph EC2Architecture {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=11
        bgcolor="BG"
        color="FG"
        fontcolor="FG"
        pad=0.5
        nodesep=0.6
        ranksep=0.8
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="4">
                <TR><TD><B><FONT POINT-SIZE="14">EC2 Compute Architecture</FONT></B></TD></TR>
                <TR><TD><FONT POINT-SIZE="9" COLOR="MUTED">Instance fleets, types, placement, and connectivity</FONT></TD></TR>
            </TABLE>
        >
        labelloc=t
    ]

    node [
        fontname="Helvetica"
        fontsize=10
        style=filled
        color="BORDER"
        fontcolor="FG"
    ]

    edge [
        fontname="Helvetica"
        fontsize=8
        fontcolor="SUBTLE"
        color="EDGE"
    ]

    web_servers_a [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Web Servers</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.10–12 (×3)</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">nginx + node.js</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">t3.medium</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Count</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">3</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.0.0/24 (us-east-1a)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    app_servers_a [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">App Servers</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.20–21 (×2)</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">Java / Spring Boot</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">t3.large</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Count</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">2</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.0.0/24 (us-east-1a)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    web_servers_b [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Web Servers</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.10–12 (×3)</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">nginx + node.js</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">t3.medium</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Count</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">3</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.1.0/24 (us-east-1b)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    app_servers_b [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">App Servers</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.20–21 (×2)</FONT></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="7" COLOR="MUTED">Java / Spring Boot</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance Type</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">t3.large</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Count</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">2</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Subnet</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">Subnet 10.0.1.0/24 (us-east-1b)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    // ── Fleet Connections ────────────────────────────
    elb -> web_servers_a [
        color="EDGE"
    ]
    elb -> web_servers_b [
        color="EDGE"
    ]
    web_servers_a -> app_servers_a [
        label="HTTP/gRPC"
        color="EDGE"
    ]
    app_servers_a -> database_primary [
        label="SQL"
        color="EDGE"
    ]
    app_servers_a -> redis_a [
        label="cache r/w"
        color="EDGE"
    ]
    web_servers_b -> app_servers_b [
        label="HTTP/gRPC"
        color="EDGE"
    ]
    app_servers_b -> database_primary [
        label="SQL"
        color="EDGE"
    ]
    app_servers_b -> redis_b [
        label="cache r/w"
        color="EDGE"
    ]

}
