digraph NetworkArchitecture {
    // Global settings
    graph [
        rankdir=LR
        compound=true
        fontname="Helvetica"
        fontsize=11
        bgcolor="BG"
        color="FG"
        fontcolor="FG"
        pad=0.3
        nodesep=0.4
        ranksep=0.6
        label=<
            <TABLE BORDER="0" CELLSPACING="8" CELLPADDING="4">
                <TR>
                    <TD COLSPAN="2" ALIGN="CENTER"><B><FONT POINT-SIZE="14">Network Architecture</FONT></B><BR/>
                    <FONT POINT-SIZE="9" COLOR="MUTED">VPC layout with firewall, NAT gateway, and internet connectivity</FONT></TD>
                </TR>
                <TR>
                    <TD ALIGN="LEFT" VALIGN="TOP" BORDER="1" COLOR="BORDER" SIDES="R" STYLE="DASHED">
                        <B><FONT POINT-SIZE="9">VPC-B — Internal / Tooling</FONT></B><BR ALIGN="LEFT"/>
                        <FONT POINT-SIZE="8" COLOR="MUTED">• Not publicly accessible<BR ALIGN="LEFT"/>
                        • Egress via NAT (fixed IP 52.14.88.201)<BR ALIGN="LEFT"/>
                        • No inbound from Internet<BR ALIGN="LEFT"/>
                        • CI/CD pulls packages via NAT gateway<BR ALIGN="LEFT"/></FONT>
                    </TD>
                    <TD ALIGN="LEFT" VALIGN="TOP">
                        <B><FONT POINT-SIZE="9">VPC-A — Production</FONT></B><BR ALIGN="LEFT"/>
                        <FONT POINT-SIZE="8" COLOR="MUTED">• Public-facing production workloads<BR ALIGN="LEFT"/>
                        • All inbound traffic filtered by firewall<BR ALIGN="LEFT"/>
                        • Egress via NAT (fixed IP 52.14.88.205)<BR ALIGN="LEFT"/>
                        • ELB distributes traffic across AZs<BR ALIGN="LEFT"/>
                        • App servers call API A and API B<BR ALIGN="LEFT"/>
                        • Multi-AZ database with read replica<BR ALIGN="LEFT"/></FONT>
                    </TD>
                </TR>
            </TABLE>
        >
        labelloc=t
    ]

    node [
        fontname="Helvetica"
        fontsize=10
        style=filled
        color="BORDER"
        fontcolor="FG"
    ]

    edge [
        fontname="Helvetica"
        fontsize=8
        fontcolor="SUBTLE"
        color="EDGE"
    ]

    // ── Internet ──────────────────────────────────────────────
    internet [
        label=""
        image="CLOUD_IMAGE"
        imagescale=true
        fixedsize=true
        width=1.4
        height=0.9
        shape=none
        style=""
    ]

    // ── Firewall ──────────────────────────────────────────────
    firewall [
        label=<
            <TABLE BORDER="0" CELLSPACING="1" CELLPADDING="1">
                <TR><TD><B>Firewall</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">IP Whitelist</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">203.0.113.10 (Partner API)</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">198.51.100.0/28 (Office)</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">192.0.2.42 (Monitoring)</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">100.21.56.78 (CI/CD)</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,bold"
        fillcolor="FIREWALL_FILL"
        color="FIREWALL"
        fontcolor="FIREWALL"
    ]

    // ── NAT Gateways ──────────────────────────────────────────

    nat_a [
        label=<
            <TABLE BORDER="0" CELLSPACING="1" CELLPADDING="1">
                <TR><TD><B>NAT Gateway</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">EIP: 52.14.88.205</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,bold"
        fillcolor="BLUE_ALT_FILL"
        color="BLUE"
        fontcolor="BLUE"
    ]

    nat_b [
        label=<
            <TABLE BORDER="0" CELLSPACING="1" CELLPADDING="1">
                <TR><TD><B>NAT Gateway</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">EIP: 52.14.88.201</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,bold"
        fillcolor="GREEN_FILL"
        color="GREEN"
        fontcolor="GREEN"
    ]

    // ── External APIs ────────────────────────────────────────

    api_a [
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                <TR><TD><B>API A</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">external service</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="BG"
        color="BORDER"
    ]

    api_b [
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                <TR><TD><B>API B</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">external service</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="BG"
        color="BORDER"
    ]

    // ── VPC-A ──────────────────────────────────────────
    subgraph cluster_vpc_a {
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                <TR><TD><B><FONT COLOR="BLUE">VPC-A</FONT></B></TD></TR>
                <TR><TD><FONT POINT-SIZE="9" COLOR="MUTED">us-east-1 · Production</FONT></TD></TR>
            </TABLE>
        >
        style="dashed,filled,rounded"
        color="BLUE"
        fillcolor="CLUSTER_FILL"
        fontcolor="BLUE"

        _anchor_a [shape=point, style=invis, width=0]


        elb [
            label=<
                <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                    <TR><TD><B>ELB</B></TD></TR>
                    <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">Application Load Balancer</FONT></TD></TR>
                </TABLE>
            >
            shape=box
            style="filled,rounded"
            fillcolor="NODE_BLUE_FILL"
            color="BLUE"
        ]
        subgraph cluster_az_a {
            label=<
                <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                    <TR><TD><B><FONT COLOR="BLUE_ALT">Subnet 10.0.0.0/24 (us-east-1a)</FONT></B></TD></TR>
                    <TR><TD><FONT POINT-SIZE="8" COLOR="MUTED">254 usable hosts · 10.0.0.1–10.0.0.254</FONT></TD></TR>
                </TABLE>
            >
            style="dashed,filled,rounded"
            color="BLUE_ALT"
            fillcolor="SUBNET_FILL"

            web_servers_a [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Web Servers</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.10–12 (×3)</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">nginx + node.js</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            app_servers_a [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>App Servers</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.20–21 (×2)</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">Java / Spring Boot</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            redis_a [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Valkey Cache</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.100</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">ElastiCache node</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            database_primary [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Database (primary)</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.50</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">PostgreSQL RDS</FONT></TD></TR>
                    </TABLE>
                >
                shape=cylinder
                style="filled"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]
        }

        subgraph cluster_az_b {
            label=<
                <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                    <TR><TD><B><FONT COLOR="BLUE_ALT">Subnet 10.0.1.0/24 (us-east-1b)</FONT></B></TD></TR>
                    <TR><TD><FONT POINT-SIZE="8" COLOR="MUTED">254 usable hosts · 10.0.1.1–10.0.1.254</FONT></TD></TR>
                </TABLE>
            >
            style="dashed,filled,rounded"
            color="BLUE_ALT"
            fillcolor="SUBNET_FILL"

            web_servers_b [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Web Servers</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.10–12 (×3)</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">nginx + node.js</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            app_servers_b [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>App Servers</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.20–21 (×2)</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">Java / Spring Boot</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            redis_b [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Valkey Cache</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.100</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">ElastiCache node</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]

            database_standby [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Database (standby)</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.50</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">PostgreSQL RDS</FONT></TD></TR>
                    </TABLE>
                >
                shape=cylinder
                style="filled"
                fillcolor="NODE_BLUE_FILL"
                color="BLUE"
            ]
        }

    }

    // ── VPC-B ──────────────────────────────────────────
    subgraph cluster_vpc_b {
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                <TR><TD><B><FONT COLOR="GREEN">VPC-B</FONT></B></TD></TR>
                <TR><TD><FONT POINT-SIZE="9" COLOR="MUTED">us-east-1 · Internal / Tooling</FONT></TD></TR>
            </TABLE>
        >
        style="dashed,filled,rounded"
        color="GREEN"
        fillcolor="CLUSTER_FILL"
        fontcolor="GREEN"

        _anchor_b [shape=point, style=invis, width=0]

        subgraph cluster_subnet_b {
            label=<
                <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                    <TR><TD><B><FONT COLOR="GREEN_ALT">Subnet 10.0.4.0/22</FONT></B></TD></TR>
                    <TR><TD><FONT POINT-SIZE="8" COLOR="MUTED">1,022 usable hosts · 10.0.4.1–10.0.7.254</FONT></TD></TR>
                </TABLE>
            >
            style="dashed,filled,rounded"
            color="GREEN_ALT"
            fillcolor="SUBNET_FILL"

            ci_cd [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>CI/CD Runners</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">172.16.1.10–13 (×4)</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">Jenkins + GH Actions</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_GREEN_FILL"
                color="GREEN"
            ]

            monitoring [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Monitoring</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">172.16.1.50</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">Prometheus + Grafana</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_GREEN_FILL"
                color="GREEN"
            ]

            artifacts [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Artifacts</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">172.16.1.100</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">S3 object store</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_GREEN_FILL"
                color="GREEN"
            ]

            logs [
                label=<
                    <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="1">
                        <TR><TD><B>Log Aggregator</B></TD></TR>
                        <TR><TD><FONT POINT-SIZE="8" COLOR="SUBTLE">172.16.1.200</FONT></TD></TR>
                        <TR><TD><FONT POINT-SIZE="7" COLOR="MUTED">ELK Stack</FONT></TD></TR>
                    </TABLE>
                >
                shape=box
                style="filled,rounded"
                fillcolor="NODE_GREEN_FILL"
                color="GREEN"
            ]
        }
    }

    // ── Edges: Internet → Firewall → VPC-A ────────────────────
    firewall -> elb [
        label="whitelisted traffic"
        color="FIREWALL"
        fontcolor="FIREWALL"
    ]
    internet -> firewall [
        label="inbound (filtered)"
        style=dashed
        color="FIREWALL"
        fontcolor="FIREWALL"
    ]

    // ── Edges: Subnet → NAT → Internet → External APIs ────────────────────
    internet -> api_a [
        label=""
        color="EDGE"
    ]
    internet -> api_b [
        label=""
        color="EDGE"
    ]
    nat_a -> internet [
        label=<egress only<BR/><FONT POINT-SIZE="7">src IP: 52.14.88.205</FONT>>
        color="BLUE"
        fontcolor="BLUE"
    ]
    nat_b -> internet [
        label=<egress only<BR/><FONT POINT-SIZE="7">src IP: 52.14.88.201</FONT>>
        color="GREEN"
        fontcolor="GREEN"
    ]
    _anchor_a -> nat_a [
        label="egress via NAT"
        style=dashed
        color="BLUE"
        fontcolor="BLUE"
        ltail=cluster_vpc_a
    ]
    _anchor_b -> nat_b [
        label="egress via NAT"
        style=dashed
        color="GREEN"
        fontcolor="GREEN"
        ltail=cluster_vpc_b
    ]

    // ── Edges: Internal VPC-A flows ────────────────────
    elb -> web_servers_a [
        label=""
        color="EDGE"
    ]
    elb -> web_servers_b [
        label=""
        color="EDGE"
    ]
    web_servers_a -> app_servers_a [
        label="HTTP/gRPC"
        color="EDGE"
    ]
    app_servers_a -> database_primary [
        label="SQL"
        color="EDGE"
    ]
    app_servers_a -> redis_a [
        label="cache r/w"
        color="EDGE"
    ]
    database_primary -> database_standby [
        label="sync replication"
        style=dashed
        color="EDGE"
    ]
    web_servers_b -> app_servers_b [
        label="HTTP/gRPC"
        color="EDGE"
    ]
    app_servers_b -> database_primary [
        label="SQL"
        color="EDGE"
    ]
    app_servers_b -> redis_b [
        label="cache r/w"
        color="EDGE"
    ]

    // ── Edges: Internal VPC-B flows ────────────────────
    ci_cd -> artifacts [
        label="push builds"
        color="EDGE"
    ]
    monitoring -> logs [
        label="alerts"
        color="EDGE"
    ]

}
