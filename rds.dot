digraph RDSArchitecture {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=11
        bgcolor="BG"
        color="FG"
        fontcolor="FG"
        pad=0.5
        nodesep=0.6
        ranksep=0.8
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="4">
                <TR><TD><B><FONT POINT-SIZE="14">RDS Database Architecture</FONT></B></TD></TR>
                <TR><TD><FONT POINT-SIZE="9" COLOR="MUTED">Instance configuration, replication, and network placement</FONT></TD></TR>
            </TABLE>
        >
        labelloc=t
    ]

    node [
        fontname="Helvetica"
        fontsize=10
        style=filled
        color="BORDER"
        fontcolor="FG"
    ]

    edge [
        fontname="Helvetica"
        fontsize=8
        fontcolor="SUBTLE"
        color="EDGE"
    ]

    database_primary [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Database (primary)</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.0.50</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Engine</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">postgres</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">${Token[TOKEN.127]}</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Storage</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">20 GB</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Multi-AZ</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">No</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    database_standby [
        label=<
            <TABLE BORDER="0" CELLSPACING="2" CELLPADDING="2">
                <TR><TD COLSPAN="2"><B><FONT POINT-SIZE="11">Database (standby)</FONT></B></TD></TR>
                <TR><TD COLSPAN="2"><FONT POINT-SIZE="8" COLOR="SUBTLE">10.0.1.50</FONT></TD></TR>
                <HR/>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Engine</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">PostgreSQL RDS</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Instance</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">${Token[TOKEN.161]}</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">Multi-AZ</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">No</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="MUTED">VPC</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="8">VPC-A</FONT></TD></TR>
            </TABLE>
        >
        shape=box
        style="filled,rounded"
        fillcolor="NODE_BLUE_FILL"
        color="BLUE"
    ]

    // ── Replication / Connections ────────────────────
    app_servers_a -> database_primary [
        label="SQL"
        color="EDGE"
    ]
    database_primary -> database_standby [
        label="sync replication"
        style=dashed
        color="EDGE"
    ]
    app_servers_b -> database_primary [
        label="SQL"
        color="EDGE"
    ]

}
